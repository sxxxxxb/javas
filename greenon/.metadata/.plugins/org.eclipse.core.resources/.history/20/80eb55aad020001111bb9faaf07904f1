package org.greenon.sql;

public interface FaqSql {

	// 단건조회
	String SELECT_FAQ = "SELECT \r\n"
			+ "    q.qna_no, q.title, q.inquiry_content, q.inquiry_date,\r\n"
			+ "    q.answer_content, q.answer_date, q.qna_status, q.is_secret,\r\n"
			+ "    q.id, q.answerer_id, q.p_no, q.pay_no, q.order_no,\r\n"
			+ "    c.category_name, d.detail_name\r\n"
			+ "FROM qna q\r\n"
			+ "JOIN qna_categories_details d ON q.qna_detail_no = d.qna_detail_no\r\n"
			+ "JOIN qna_categories c ON d.qna_category_no = c.qna_category_no\r\n"
			+ "WHERE q.qna_no = :qnaId";
	
	String 
}


