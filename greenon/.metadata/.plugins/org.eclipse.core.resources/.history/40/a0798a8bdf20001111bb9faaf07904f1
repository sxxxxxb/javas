import lombok.RequiredArgsConstructor;
import org.springframework.stereotype.Service;
import org.springframework.transaction.annotation.Transactional;

import java.util.List;

@Service
@RequiredArgsConstructor
public class QnaService {

    // DB와 통신하는 매퍼(또는 Repository) 인터페이스를 주입받습니다.
    private final QnaMapper qnaMapper;

    /**
     * 1. 구매자: 문의글 작성 (C)
     */
    @Transactional
    public void createQna(QnaCreateRequest request, String userId) {
        qnaMapper.insertQna(request, userId);
    }

    /**
     * 2. 공통: 특정 상품의 문의 목록 조회 (R)
     */
    @Transactional(readOnly = true)
    public List<QnaListResponse> getQnaListByProduct(Integer productId, int page, int size) {
        // LIMIT과 OFFSET 계산식 (앞서 설명해 드렸던 백엔드 페이징 공식입니다)
        int offset = (page - 1) * size;
        
        // 조인 쿼리가 실행되어 결과를 Response DTO 리스트로 반환합니다.
        return qnaMapper.selectQnaListByProduct(productId, size, offset);
    }

    /**
     * 3. 구매자: 내 문의글 수정 (U)
     */
    @Transactional
    public void updateQna(Long qnaNo, QnaUpdateRequest request, String userId) {
        // 핵심 버그 방지 로직: 이미 답변이 달린 글은 수정할 수 없도록 Mapper의 SQL 조건절(qna_status = 'WAITING')에서 걸러집니다.
        int updatedRow = qnaMapper.updateQna(qnaNo, request, userId);
        
        if (updatedRow == 0) {
            throw new IllegalArgumentException("수정할 수 없는 상태이거나 권한이 없습니다.");
        }
    }

    /**
     * 4. 판매자: 답변 작성 및 상태 변경 (U)
     */
    @Transactional
    public void createAnswer(Long qnaNo, AnswerRequest request, String sellerId) {
        // 답변 내용을 UPDATE 하고, 동시에 qna_status를 'COMPLETED'로 변경합니다.
        // 하나의 트랜잭션 안에서 묶여서 처리되므로 데이터의 상태가 틀어지지 않습니다.
        qnaMapper.updateAnswer(qnaNo, request.getAnswerContent(), sellerId);
    }

    /**
     * 5. 판매자: 답변 삭제 및 상태 롤백 (D)
     */
    @Transactional
    public void deleteAnswer(Long qnaNo, String sellerId) {
        // 답변 내용을 NULL로 업데이트하고, 상태를 다시 'WAITING'으로 되돌립니다.
        qnaMapper.deleteAnswer(qnaNo, sellerId);
    }
}