package org.greenon.repository;

import java.util.List;

import org.greenon.dto.CategoryResponse;
import org.greenon.dto.CreateQnaRequest;
import org.greenon.dto.ModifyQnaRequest;
import org.greenon.dto.QnaListResponse;
import org.springframework.data.repository.query.Param;
 
@Mapper
public interface QnaMapper {

    // [공통] 카테고리 목록 조회
    List<CategoryResponse> selectCategories();

    // [공통] 특정 상품의 문의 목록 조회 (페이징)
    List<QnaListResponse> selectQnaListByProduct(
            @Param("productId") Integer productId, 
            @Param("limit") int limit, 
            @Param("offset") int offset
    );

    // [구매자] 문의글 작성 (INSERT)
    void insertQna(
            @Param("request") CreateQnaRequest request, 
            @Param("userId") String userId
    );

    // [구매자] 내 문의 목록 조회 (페이징)
    List<QnaListResponse> selectMyQnaList(
            @Param("userId") String userId, 
            @Param("limit") int limit, 
            @Param("offset") int offset
    );

    // [구매자] 문의글 수정 (WAITING 상태일 때만 성공하여 1을 반환)
    int updateQna(
            @Param("qnaNo") Long qnaNo, 
            @Param("request") ModifyQnaRequest request, 
            @Param("userId") String userId
    );

    // [구매자] 문의글 삭제 (WAITING 상태일 때만 성공하여 1을 반환)
    int deleteQna(
            @Param("qnaNo") Long qnaNo, 
            @Param("userId") String userId
    );

    // [보조] 사진 삭제 (외래키 제약조건 위배 방지용)
    int deleteQnaPhoto(@Param("qnaNo") Long qnaNo);

    // [판매자] 답변 작성 및 상태 업데이트 (COMPLETED)
    int updateAnswer(
            @Param("qnaNo") Long qnaNo, 
            @Param("answerContent") String answerContent, 
            @Param("sellerId") String sellerId
    );
}